{
  "name": "ghana-payments",
  "version": "0.1.0",
  "description": "Ghana street vendor digital payment & soundbox platform — self-contained AWS serverless app (CDK)",
  "type": "module",
  "private": true,
  "bin": { "ghana-payments": "bin/app.ts" },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "watch": "tsc -p tsconfig.build.json -w",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --passWithNoTests",
    "test:integration": "node test/integration/run.mjs",
    "lint": "eslint src bin lib --ext .ts",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "./scripts/deploy.sh",
    "destroy": "./scripts/destroy.sh"
  },
  "dependencies": {
    "@aws-sdk/client-api-gateway": "^3.1085.0",
    "@aws-sdk/client-cognito-identity": "^3.1085.0",
    "@aws-sdk/client-cost-explorer": "^3.1085.0",
    "@aws-sdk/client-dynamodb": "^3.1085.0",
    "@aws-sdk/client-eventbridge": "^3.1085.0",
    "@aws-sdk/client-iot": "^3.1085.0",
    "@aws-sdk/client-iot-data-plane": "^3.1085.0",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/client-sqs": "^3.1085.0",
    "@aws-sdk/client-ssm": "^3.1085.0",
    "@aws-sdk/lib-dynamodb": "^3.1085.0",
    "aws-cdk-lib": "^2.160.0",
    "constructs": "^10.3.0",
    "mqtt": "^5.15.2",
    "qrcode": "^1.5.4",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.0",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^9.0.8",
    "aws-cdk": "^2.160.0",
    "aws-sdk-client-mock": "^4.1.0",
    "esbuild": "^0.24.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
