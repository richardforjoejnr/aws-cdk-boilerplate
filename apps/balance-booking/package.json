{
  "name": "balance-booking",
  "version": "0.1.0",
  "description": "Balance Booking (Pilates studio booking) — self-contained AWS serverless app (CDK)",
  "type": "module",
  "private": true,
  "bin": { "balance-booking": "bin/app.ts" },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "test": "jest --passWithNoTests",
