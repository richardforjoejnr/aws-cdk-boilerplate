{
  "name": "jira-dashboard",
  "version": "0.1.0",
  "description": "Jira analytics dashboard — self-contained AWS serverless app (CDK)",
  "type": "module",
  "private": true,
  "bin": { "jira-dashboard": "bin/app.ts" },
  "scripts": {
    "build": "tsc -p tsconfig.json --noEmit",
    "test": "jest --passWithNoTests",
    "synth": "cdk synth",
    "diff": "cdk diff",
    "deploy": "./scripts/deploy.sh",
    "destroy": "./scripts/destroy.sh"
  },
  "dependencies": {
    "@aws-sdk/client-cost-explorer": "^3.1085.0",
    "@aws-sdk/client-dynamodb": "^3.1085.0",
    "@aws-sdk/client-s3": "^3.1085.0",
    "@aws-sdk/client-sfn": "^3.1085.0",
    "@aws-sdk/lib-dynamodb": "^3.1085.0",
    "@aws-sdk/s3-request-presigner": "^3.1085.0",
    "aws-cdk-lib": "^2.160.0",
    "constructs": "^10.3.0",
    "csv-parse": "^5.5.3",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.145",
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "aws-cdk": "^2.160.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
